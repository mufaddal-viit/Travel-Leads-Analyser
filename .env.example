# ─── Groq API ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use for lead analysis (llama3-70b-8192 recommended for accuracy)
GROQ_MODEL=llama3-70b-8192

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Path to the service account JSON credentials file downloaded from Google Cloud
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Name of the Google Sheet to write results to (created automatically if missing)
GOOGLE_SHEET_NAME=Lead Qualification Results
