# ─── Groq API ─────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Model to use for lead analysis (llama3-70b-8192 recommended for accuracy)
GROQ_MODEL=llama3-70b-8192

# ─── Google Sheets (pipeline — write via service account) ────────────────────
# Path to the service account JSON credentials file downloaded from Google Cloud
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json

# Name of the Google Sheet to write results to (created automatically if missing)
GOOGLE_SHEET_NAME=Lead Qualification Results

# ─── Dashboard (read-only API key for the browser dashboard) ─────────────────
# Get your API key at: https://console.cloud.google.com/ → APIs & Services → Credentials
# Restrict it to Google Sheets API only
GOOGLE_SHEETS_API_KEY=your_google_sheets_api_key_here

# The spreadsheet ID from the Google Sheet URL:
# https://docs.google.com/spreadsheets/d/<SPREADSHEET_ID>/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# The tab name inside the spreadsheet (bottom tab label)
SHEET_NAME=Sheet1
